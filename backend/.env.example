# Example Backend Environment Variables
# Copy this file to .env and fill in the values provided by the Team Lead.

PORT=5000
NODE_ENV=development
JWT_SECRET=your_super_secret_jwt_key_here
FRONTEND_URL=http://localhost:5173

# Note: For Firebase Admin, you should obtain the serviceAccountKey.json 
# from your Team Lead and place it in the backend/config/ folder.
# DO NOT COMMIT THE serviceAccountKey.json FILE!
